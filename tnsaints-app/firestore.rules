rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userRole() {
      return userDoc().role;
    }

    function isSuperAdmin() {
      return isSignedIn() && userRole() == 'superadmin';
    }

    function isAdminOrAbove() {
      return isSignedIn() && (userRole() == 'superadmin' || userRole() == 'admin');
    }

    function isMemberOfTeam(teamId) {
      return isSignedIn() && (isSuperAdmin() || teamId in userDoc().teamIds);
    }

    function isTeamAdminOrCoach(teamId) {
      return isSuperAdmin()
        || (isMemberOfTeam(teamId) && (userRole() == 'admin' || userRole() == 'coach'));
    }

    // ── User profiles ─────────────────────────────────────────────────
    match /users/{uid} {
      // Users can read their own profile; admin+ can read any
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdminOrAbove());

      // Users can create their own profile on signup
      allow create: if isSignedIn() && request.auth.uid == uid;

      // Own profile: can update non-role fields.
      // Admin: can change roles within own team (but not to superadmin).
      // Superadmin: can change anything.
      allow update: if isSignedIn() && (
        (request.auth.uid == uid && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        || (isSuperAdmin())
        || (userRole() == 'admin'
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])
            || (request.resource.data.role != 'superadmin'))
      );

      allow delete: if isSuperAdmin();
    }

    // ── Teams ─────────────────────────────────────────────────────────
    match /teams/{teamId} {
      // Superadmin can read all; members can read their own
      allow read: if isMemberOfTeam(teamId);

      // Only superadmin can create or delete teams
      allow create: if isSuperAdmin();
      allow delete: if isSuperAdmin();

      // Admin (team-scoped) or coach can update; superadmin always
      allow update: if isTeamAdminOrCoach(teamId);

      // ── Roster (players / parents / coaches entries) ──────────────
      match /players/{playerId} {
        allow read: if isMemberOfTeam(teamId);
        allow create: if isTeamAdminOrCoach(teamId);
        allow update: if isTeamAdminOrCoach(teamId);
        allow delete: if isTeamAdminOrCoach(teamId);
      }

      // ── Events ────────────────────────────────────────────────────
      match /events/{eventId} {
        allow read: if isMemberOfTeam(teamId);
        allow write: if isTeamAdminOrCoach(teamId);
      }

      // ── Availability ──────────────────────────────────────────────
      match /availability/{entryId} {
        allow read: if isTeamAdminOrCoach(teamId);
        // Members can create/update their own availability
        allow create: if isMemberOfTeam(teamId);
        allow update: if isMemberOfTeam(teamId) && resource.data.uid == request.auth.uid;
        allow delete: if false;
      }

      // ── Chat messages ─────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if isMemberOfTeam(teamId);
        allow create: if isMemberOfTeam(teamId);
        // Owner can edit their own message (text only); admins cannot edit others'
        allow update: if isMemberOfTeam(teamId)
          && resource.data.uid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['text', 'editedAt']);
        // Owner can delete own; admin+ can delete any
        allow delete: if isMemberOfTeam(teamId)
          && (resource.data.uid == request.auth.uid || isAdminOrAbove());
      }

      // ── Files ─────────────────────────────────────────────────────
      match /files/{fileId} {
        allow read: if isMemberOfTeam(teamId);
        allow create: if isTeamAdminOrCoach(teamId);
        // Owner can delete own; admin+ can delete any
        allow delete: if isTeamAdminOrCoach(teamId)
          || (isMemberOfTeam(teamId) && resource.data.uploadedBy == request.auth.uid);
        allow update: if isTeamAdminOrCoach(teamId);
      }

      // ── Stats ─────────────────────────────────────────────────────
      match /stats/{statId} {
        allow read: if isMemberOfTeam(teamId);
        allow write: if isTeamAdminOrCoach(teamId);
      }

      // ── Invoices ──────────────────────────────────────────────────
      match /invoices/{invoiceId} {
        // Admin+ sees all; parent/player see own
        allow read: if isAdminOrAbove()
          || (isMemberOfTeam(teamId) && resource.data.recipientUid == request.auth.uid);
        allow create: if isAdminOrAbove() && isMemberOfTeam(teamId);
        allow update: if isAdminOrAbove() && isMemberOfTeam(teamId);
        allow delete: if isSuperAdmin();
      }

      // ── Alerts ────────────────────────────────────────────────────
      match /alerts/{alertId} {
        allow read: if isMemberOfTeam(teamId);
        allow create: if isTeamAdminOrCoach(teamId);
        allow update, delete: if isTeamAdminOrCoach(teamId);
      }
    }

    // ── Invites ───────────────────────────────────────────────────────
    match /invites/{inviteId} {
      allow read: if isSignedIn() && (
        isAdminOrAbove()
        || resource.data.email == request.auth.token.email
      );
      allow create: if isSignedIn() && (isAdminOrAbove() || userRole() == 'coach');
      allow update: if isAdminOrAbove();
      allow delete: if isAdminOrAbove();
    }

    // ── Deny everything else ──────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
